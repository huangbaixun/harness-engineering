#!/bin/bash
# init.sh — Harness 会话启动脚本
# 每次开始新的 Claude Code 会话前运行：bash init.sh
# 生成自：harness-engineering plugin / harness-init Skill

set -euo pipefail

PROJECT_NAME="{{PROJECT_NAME}}"
PROGRESS_FILE="docs/claude-progress.json"
FEATURES_FILE="docs/features.json"

echo "════════════════════════════════════"
echo "  ${PROJECT_NAME} — Harness 就绪检查"
echo "════════════════════════════════════"

# 1. 当前进度
if [ -f "$PROGRESS_FILE" ]; then
  echo ""
  echo "📋 当前任务进度："
  python3 - <<'PYEOF'
import json, sys

try:
    with open("docs/claude-progress.json") as f:
        d = json.load(f)
    current = d.get("current_task", "无")
    completed = d.get("completed", [])
    blocked = d.get("blockers", [])
    print(f"  当前任务：{current}")
    print(f"  已完成：{len(completed)} 项 — {', '.join(completed) if completed else '无'}")
    if blocked:
        print(f"  ⚠️  阻塞项：{', '.join(blocked)}")
except Exception as e:
    print(f"  （进度文件读取失败：{e}）")
PYEOF
else
  echo ""
  echo "📋 首次会话，尚无进度记录"
fi

# 2. 待实现特性
if [ -f "$FEATURES_FILE" ]; then
  echo ""
  echo "📌 特性清单："
  python3 - <<'PYEOF'
import json

try:
    with open("docs/features.json") as f:
        features = json.load(f)
    pending = [f for f in features if f.get("status") == "pending"]
    in_progress = [f for f in features if f.get("status") == "in_progress"]
    done = [f for f in features if f.get("status") == "done"]
    print(f"  进行中：{len(in_progress)} | 待处理：{len(pending)} | 已完成：{len(done)}")
    for f in in_progress:
        print(f"  → {f.get('id','?')}: {f.get('title','')}")
except Exception as e:
    print(f"  （特性文件读取失败：{e}）")
PYEOF
fi

# 3. 架构文档提示
echo ""
echo "📐 架构文档：docs/architecture.md"
echo "📖 Agent 记忆：CLAUDE.md"
echo ""
echo "════════════════════════════════════"
echo "  Harness 就绪，可以开始会话 ✓"
echo "════════════════════════════════════"
