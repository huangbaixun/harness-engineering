{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_PLUGIN_ROOT:-.}/scripts/session-start\" \"$@\"' --"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_PLUGIN_ROOT:-.}/scripts/stop-typecheck\" \"$@\"' --"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_PLUGIN_ROOT:-.}/scripts/stop-commit-progress\" \"$@\"' --"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_PLUGIN_ROOT:-.}/scripts/pre-protect-env\" \"$@\"' --"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_PLUGIN_ROOT:-.}/scripts/post-format\" \"$@\"' --"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_PLUGIN_ROOT:-.}/scripts/post-observe\" \"$@\"' --"
          }
        ]
      }
    ]
  }
}
